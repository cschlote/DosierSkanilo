    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "Launch Program (CodeLLDB): With Save",
            "program": "${workspaceFolder}/build/bin/dosierskanilo",
            "args": [
                "--path=./",
                "-r",
                "--json=.filescanner.json",
                "-v",
                // "-s",
                "-y",
                "-m", // "--rescan-mediasig",
                "-c",
                // "-o",
                "-a",
                "-z",
                "-w","-f",
                "-t0"
            ],
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Launch Program (CodeLLDB): No Save",
            "program": "${workspaceFolder}/filescanner",
            "args": [
                "--path=./",
                "-r",
                "--json=.filescanner.json",
                "-v",
                // "-s",
                "-y",
                "-m", // "--rescan-mediasig",
                "-c",
                // "-o",
                "-a",
                "-z",
                //"-w","-f",
                "-t0"
            ],
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Launch Testbench (CodeLLDB)",
            "program": "${workspaceFolder}/build/bin/dosierskanilo-test-application",
            "args": [
                "--",
                "-v",
                // "-i", "class FileArchive7z"
            ],
            "cwd": "${workspaceFolder}"
        }
    ]
}