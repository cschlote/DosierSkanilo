{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build-host",
            "type": "shell",
            "command": "dub build --compiler=ldc2",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "build-docs",
            "type": "shell",
            "command": "dub run adrdox -- ${workspaceFolder} -o docs -i --skeleton ${workspaceFolder}/skeleton.html && cp -f ${workspaceFolder}/dosierskanilo-icon.svg ${workspaceFolder}/docs/dosierskanilo-icon.svg && RELEASE_TAG=$(git -C ${workspaceFolder} describe --tags --abbrev=0 2>/dev/null || echo v0.0.0) && RELEASE_BRANCH=$(git -C ${workspaceFolder} rev-parse --abbrev-ref HEAD 2>/dev/null || echo main) && RELEASE_COMMIT=$(git -C ${workspaceFolder} rev-parse --short HEAD 2>/dev/null || echo unknown) && BUILD_ISO=$(date -u +%Y-%m-%dT%H:%M:%SZ) && printf '{\n  \"releaseTag\": \"%s\",\n  \"branch\": \"%s\",\n  \"commit\": \"%s\",\n  \"compiler\": \"ldc2\",\n  \"buildDateUtc\": \"%s\",\n  \"changelogUrl\": \"https://github.com/cschlote/DosierSkanilo/blob/main/CHANGELOG.md\",\n  \"releaseUrl\": \"https://github.com/cschlote/DosierSkanilo/releases/tag/%s\"\n}\n' \"$RELEASE_TAG\" \"$RELEASE_BRANCH\" \"$RELEASE_COMMIT\" \"$BUILD_ISO\" \"$RELEASE_TAG\" > ${workspaceFolder}/docs/meta.json",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "run-docs",
            "type": "shell",
            "command": "dub run adrdox -- ${workspaceFolder} -o docs -i --skeleton ${workspaceFolder}/skeleton.html && cp -f ${workspaceFolder}/dosierskanilo-icon.svg ${workspaceFolder}/docs/dosierskanilo-icon.svg && RELEASE_TAG=$(git -C ${workspaceFolder} describe --tags --abbrev=0 2>/dev/null || echo v0.0.0) && RELEASE_BRANCH=$(git -C ${workspaceFolder} rev-parse --abbrev-ref HEAD 2>/dev/null || echo main) && RELEASE_COMMIT=$(git -C ${workspaceFolder} rev-parse --short HEAD 2>/dev/null || echo unknown) && BUILD_ISO=$(date -u +%Y-%m-%dT%H:%M:%SZ) && printf '{\n  \"releaseTag\": \"%s\",\n  \"branch\": \"%s\",\n  \"commit\": \"%s\",\n  \"compiler\": \"ldc2\",\n  \"buildDateUtc\": \"%s\",\n  \"changelogUrl\": \"https://github.com/cschlote/DosierSkanilo/blob/main/CHANGELOG.md\",\n  \"releaseUrl\": \"https://github.com/cschlote/DosierSkanilo/releases/tag/%s\"\n}\n' \"$RELEASE_TAG\" \"$RELEASE_BRANCH\" \"$RELEASE_COMMIT\" \"$BUILD_ISO\" \"$RELEASE_TAG\" > ${workspaceFolder}/docs/meta.json",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "test-host",
            "type": "shell",
            "command": "dub test --compiler=ldc2 -b unittest-cov -- -v",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "clean",
            "type": "shell",
            "command": "dub clean -v",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "build-doxygen",
            "type": "shell",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "command": "dub clean -v",
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}