{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build-host",
            "type": "shell",
            "command": "dub build --compiler=ldc2",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "build-ddox",
            "type": "shell",
            "command": "dub build --compiler=ldc2 --build=ddox",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "run-ddox",
            "type": "shell",
            "command": "dub run --compiler=ldc2 --build=ddox",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "test-host",
            "type": "shell",
            "command": "dub test -b unittest-cov -- -v",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "clean",
            "type": "shell",
            "command": "dub clean -v",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "build-doxygen",
            "type": "shell",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "command": "dub clean -v",
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}